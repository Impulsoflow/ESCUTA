<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Como Você Ouve as Pessoas - Avaliação de Escuta Ativa</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/3.9.1/chart.min.js"></script>
    <style>
        body {
            background: linear-gradient(135deg, #667eea, #764ba2);
        }
        .option {
            transition: all 0.3s ease;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        }
        .option:hover {
            transform: scale(1.05);
            background-color: #fef3c7;
        }
        .option.selected {
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: white;
            border-color: #5568d3;
        }
        .btn-primary {
            background: linear-gradient(135deg, #667eea, #764ba2);
            animation: pulse 2s infinite;
        }
        .btn-primary:hover {
            background: linear-gradient(135deg, #764ba2, #667eea);
        }
        .btn-secondary {
            background: linear-gradient(135deg, #6b7280, #4b5563);
        }
        .btn-secondary:hover {
            background: linear-gradient(135deg, #4b5563, #6b7280);
        }
        @keyframes pulse {
            0% { transform: scale(1); }
            50% { transform: scale(1.05); }
            100% { transform: scale(1); }
        }
        .input-icon {
            position: relative;
        }
        .input-icon svg {
            position: absolute;
            left: 10px;
            top: 50%;
            transform: translateY(-50%);
            width: 20px;
            height: 20px;
            color: #4b5563;
        }
        .input-icon input {
            padding-left: 40px;
        }
        .tips-highlight {
            animation: tipsPulse 2s infinite alternate;
            box-shadow: 
                0 0 12px rgba(102, 126, 234, 0.7),
                0 0 24px rgba(118, 75, 162, 0.5);
            border: 2px solid #667eea;
            border-radius: 12px;
        }
        @keyframes tipsPulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.01); }
        }
        .module-title {
            font-size: 1.3rem;
            font-weight: bold;
            text-align: center;
            padding: 6px 12px;
            border-radius: 10px;
            margin-bottom: 12px;
            color: white;
            text-shadow: 0 1px 2px rgba(0,0,0,0.2);
            background: linear-gradient(135deg, #667eea, #764ba2);
        }
        .alert-warning {
            background-color: #fef3c7;
            border-left: 4px solid #f59e0b;
            padding: 16px;
            border-radius: 8px;
            margin-top: 12px;
        }
        .alert-danger {
            background-color: #fee2e2;
            border-left: 4px solid #ef4444;
            padding: 16px;
            border-radius: 8px;
            margin-top: 12px;
            animation: pulse-alert 1.5s infinite;
        }
        @keyframes pulse-alert {
            0%, 100% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.7); }
            50% { box-shadow: 0 0 0 10px rgba(239, 68, 68, 0); }
        }
        .alert-success {
            background-color: #d1fae5;
            border-left: 4px solid #10b981;
            padding: 16px;
            border-radius: 8px;
            margin-top: 12px;
        }
        .chart-container {
            position: relative;
            width: 100%;
            max-width: 600px;
            margin: 0 auto;
        }
        .area-info {
            padding: 12px;
            border-radius: 8px;
            margin-bottom: 12px;
            border-left: 4px solid;
        }
    </style>
</head>
<body class="min-h-screen flex items-center justify-center p-4">
    <div class="max-w-4xl w-full bg-white rounded-2xl shadow-2xl p-6 sm:p-8">
        <h2 class="text-3xl sm:text-4xl font-bold text-center text-transparent bg-clip-text bg-gradient-to-r from-purple-600 to-indigo-600 mb-2">Impulso Coaching</h2>
        <h1 class="text-4xl sm:text-5xl font-extrabold text-center text-transparent bg-clip-text bg-gradient-to-r from-indigo-600 to-purple-600 mb-2">Como Você Ouve as Pessoas</h1>
        <p class="text-center text-gray-600 mb-6">Avalie suas habilidades de Escuta Ativa em 12 dimensões essenciais.</p>
        
        <div id="form-section">
            <div class="bg-gradient-to-r from-purple-100 to-indigo-100 p-6 rounded-lg mb-6 shadow-md">
                <p class="text-xl font-semibold text-gray-800 mb-4">Dados Pessoais</p>
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-4">
                    <div class="input-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                        <input type="text" id="name" placeholder="Nome" class="border border-purple-300 rounded-lg p-3 w-full focus:outline-none focus:ring-2 focus:ring-purple-500 bg-gradient-to-r from-white to-purple-50">
                    </div>
                    <div class="input-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                        <input type="number" id="age" placeholder="Idade" class="border border-purple-300 rounded-lg p-3 w-full focus:outline-none focus:ring-2 focus:ring-purple-500 bg-gradient-to-r from-white to-purple-50">
                    </div>
                    <div class="input-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                        <input type="text" id="occupation" placeholder="Profissão" class="border border-purple-300 rounded-lg p-3 w-full focus:outline-none focus:ring-2 focus:ring-purple-500 bg-gradient-to-r from-white to-purple-50">
                    </div>
                </div>
                <div class="input-icon mb-6">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                    <input type="email" id="email" placeholder="Email" class="border border-purple-300 rounded-lg p-3 w-full focus:outline-none focus:ring-2 focus:ring-purple-500 bg-gradient-to-r from-white to-purple-50">
                </div>
                <div class="tips-highlight bg-gradient-to-r from-purple-100 to-indigo-100 p-6 rounded-lg mb-6 shadow-md">
                    <p class="text-xl font-semibold text-gray-800 mb-4">Como Usar Esta Ferramenta:</p>
                    <ul class="list-disc list-inside text-gray-700 space-y-2">
                        <li>Avalie cada afirmação de 1 a 10, onde 1 é "Discordo Totalmente" e 10 é "Concordo Totalmente".</li>
                        <li>Seja sincera(o) em suas respostas - não há respostas certas ou erradas.</li>
                        <li>Pense em suas habilidades de escuta e como você se relaciona com os outros.</li>
                        <li>Use os resultados para identificar suas forças e áreas de desenvolvimento em escuta ativa.</li>
                    </ul>
                </div>
                <div class="flex justify-end">
                    <button onclick="startTest()" class="btn-primary text-white px-6 py-3 rounded-lg transition shadow-md">Iniciar Pesquisa</button>
                </div>
            </div>
        </div>

        <div id="test-section" class="hidden">
            <p class="text-center text-gray-600 mb-4 text-lg">Avalie cada área de 1 a 10</p>
            
            <div class="mb-6">
                <div class="flex justify-between items-center mb-2">
                    <span id="progress-text" class="text-gray-600 font-semibold">Área 1 de 12</span>
                    <span class="text-purple-600 font-semibold" id="progress-percent">8%</span>
                </div>
                <div class="w-full bg-gray-300 rounded-full h-3">
                    <div id="progress-bar" class="bg-gradient-to-r from-purple-500 to-indigo-500 h-3 rounded-full" style="width: 8%;"></div>
                </div>
            </div>
            
            <div id="questions"></div>
            <div class="flex justify-between mt-8">
                <button onclick="previousQuestion()" class="btn-secondary text-white px-6 py-3 rounded-lg transition shadow-md disabled:opacity-50" id="prev-btn">Anterior</button>
                <button onclick="nextQuestion()" class="btn-primary text-white px-6 py-3 rounded-lg transition shadow-md" id="next-btn">Próxima</button>
            </div>
        </div>

        <div id="result-section" class="hidden">
            <div class="text-center mb-8">
                <h2 class="text-3xl font-bold text-center text-transparent bg-clip-text bg-gradient-to-r from-purple-600 to-indigo-600 mb-2">Seus Resultados</h2>
                <p class="text-2xl font-semibold text-gray-800" id="result-name"></p>
            </div>
            
            <div class="chart-container mb-8">
                <canvas id="wheelChart"></canvas>
            </div>

            <div id="areas-info" class="space-y-4 mb-8"></div>

            <div id="total-section" class="mt-10 p-6 bg-gradient-to-r from-purple-100 to-indigo-100 rounded-xl shadow-inner">
                <h3 class="text-2xl font-bold text-indigo-900 mb-3 text-center">Nível Geral de Escuta Ativa</h3>
                <div class="text-center">
                    <div class="text-6xl font-bold text-purple-600" id="total-score">0</div>
                    <p class="text-gray-800 text-center mt-2">Seu nível geral de habilidade de escuta ativa</p>
                </div>
                <div id="total-explanation" class="mt-6"></div>
            </div>

            <div class="flex justify-center gap-4 mt-8 flex-wrap">
                <button onclick="generatePDF()" class="btn-primary text-white px-6 py-3 rounded-lg transition shadow-md">Baixar Resultado em PDF</button>
                <button onclick="resetTest()" class="btn-secondary text-white px-6 py-3 rounded-lg transition shadow-md">Fazer Novamente</button>
            </div>
        </div>
    </div>

    <script>
        const areas = [
            { name: 'Foco e Presença', description: 'Eu consigo dar atenção total ao interlocutor, evitando distrações (celular, pensamentos, etc.).' },
            { name: 'Não Interrupção', description: 'Eu evito interromper a fala da outra pessoa, mesmo quando discordo ou tenho algo a acrescentar.' },
            { name: 'Empatia e Julgamento', description: 'Eu escuto sem julgar ou formular uma resposta enquanto a pessoa ainda está falando.' },
            { name: 'Confirmação Verbal', description: 'Eu uso frases como "Entendo", "Certo" ou "Continue" para mostrar que estou acompanhando ativamente.' },
            { name: 'Linguagem Corporal', description: 'Eu mantenho contato visual, aceno com a cabeça e uso uma postura aberta para encorajar a fala.' },
            { name: 'Questionamento', description: 'Eu faço perguntas abertas e relevantes para aprofundar a conversa e obter mais detalhes.' },
            { name: 'Reflexão e Resumo', description: 'Eu repito ou resumo o que ouvi com minhas próprias palavras para confirmar meu entendimento ("Se entendi bem, você está dizendo que...").' },
            { name: 'Gerenciamento Emocional', description: 'Eu consigo manter a calma e a neutralidade, mesmo quando a mensagem da outra pessoa me provoca emocionalmente.' },
            { name: 'Memória e Retenção', description: 'Eu consigo lembrar dos pontos principais da conversa após ela terminar.' },
            { name: 'Feedback Construtivo', description: 'Eu dou feedback de forma clara e respeitosa, focado no comportamento e não na pessoa.' },
            { name: 'Percepção de Não-Verbal', description: 'Eu presto atenção aos sinais não-verbais (tom de voz, expressões faciais) para entender o sentimento por trás das palavras.' },
            { name: 'Ação Pós-Escuta', description: 'Eu tomo ações ou faço acompanhamento com base no que foi discutido, mostrando que a escuta gerou resultados.' }
        ];

        const colors = ['#FF6B6B','#FFA500','#FFD93D','#6BCB77','#4D96FF','#9D84B7','#FF69B4','#00CED1','#FFB6C1','#87CEEB','#DDA0DD','#F0E68C'];

        const responses = new Array(areas.length).fill(1);
        let currentQuestion = 0;
        let userData = {};
        let chart = null;

        function startTest() {
            const name = document.getElementById('name').value.trim();
            const email = document.getElementById('email').value.trim();

            if (!name || !email) {
                alert('Por favor, preencha o nome e o email.');
                return;
            }

            userData = {
                name,
                email,
                age: document.getElementById('age').value,
                occupation: document.getElementById('occupation').value.trim()
            };

            document.getElementById('form-section').classList.add('hidden');
            document.getElementById('test-section').classList.remove('hidden');
            renderQuestion();
        }

        function renderQuestion() {
            const questionsDiv = document.getElementById('questions');
            questionsDiv.innerHTML = '';

            const area = areas[currentQuestion];
            const questionDiv = document.createElement('div');
            questionDiv.className = 'bg-purple-50 p-6 rounded-lg shadow-sm mb-6';

            const titleDiv = document.createElement('div');
            titleDiv.className = 'module-title mb-4';
            titleDiv.textContent = `Área ${currentQuestion + 1} de ${areas.length}`;
            questionDiv.appendChild(titleDiv);

            const areaName = document.createElement('p');
            areaName.className = 'text-lg text-gray-800 mb-2 font-semibold';
            areaName.textContent = area.name;
            questionDiv.appendChild(areaName);

            const areaDesc = document.createElement('p');
            areaDesc.className = 'text-gray-700 mb-6';
            areaDesc.textContent = area.description;
            questionDiv.appendChild(areaDesc);

            const sliderContainer = document.createElement('div');
            sliderContainer.className = 'mb-6';

            const label = document.createElement('label');
            label.className = 'block text-gray-700 font-semibold mb-2';
            label.textContent = `Concordância: ${responses[currentQuestion]} / 10`;
            label.id = 'slider-label';
            sliderContainer.appendChild(label);

            const slider = document.createElement('input');
            slider.type = 'range';
            slider.min = '1';
            slider.max = '10';
            slider.value = responses[currentQuestion];
            slider.className = 'w-full h-3 bg-gray-300 rounded-lg appearance-none cursor-pointer accent-purple-600';
            slider.oninput = function() {
                responses[currentQuestion] = parseInt(this.value);
                document.getElementById('slider-label').textContent = `Concordância: ${this.value} / 10`;
            };
            sliderContainer.appendChild(slider);

            questionDiv.appendChild(sliderContainer);
            questionsDiv.appendChild(questionDiv);

            const progressPercent = Math.round(((currentQuestion + 1) / areas.length) * 100);
            document.getElementById('progress-text').textContent = `Área ${currentQuestion + 1} de ${areas.length}`;
            document.getElementById('progress-percent').textContent = progressPercent + '%';
            document.getElementById('progress-bar').style.width = progressPercent + '%';

            document.getElementById('prev-btn').disabled = currentQuestion === 0;
            document.getElementById('next-btn').textContent = currentQuestion === areas.length - 1 ? 'Ver Resultados' : 'Próxima';
        }

        function nextQuestion() {
            if (currentQuestion < areas.length - 1) {
                currentQuestion++;
                renderQuestion();
            } else {
                showResults();
            }
        }

        function previousQuestion() {
            if (currentQuestion > 0) {
                currentQuestion--;
                renderQuestion();
            }
        }

        function showResults() {
            document.getElementById('test-section').classList.add('hidden');
            document.getElementById('result-section').classList.remove('hidden');

            const totalScore = parseFloat((responses.reduce((a, b) => a + b, 0) / areas.length).toFixed(1));

            document.getElementById('result-name').textContent = userData.name;
            document.getElementById('total-score').textContent = totalScore;

            renderChart(responses);
            renderAreasInfo(responses);
            renderTotalExplanation(totalScore, responses);
        }

        function renderChart(scores) {
            const ctx = document.getElementById('wheelChart').getContext('2d');
            if (chart) chart.destroy();

            chart = new Chart(ctx, {
                type: 'radar',
                data: {
                    labels: areas.map(a => a.name),
                    datasets: [{
                        label: 'Sua Pontuação',
                        data: scores,
                        borderColor: '#667eea',
                        backgroundColor: 'rgba(102, 126, 234, 0.15)',
                        borderWidth: 3,
                        pointBackgroundColor: colors,
                        pointBorderColor: '#fff',
                        pointBorderWidth: 3,
                        pointRadius: 7,
                        pointHoverRadius: 10,
                        fill: true,
                        tension: 0.4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: true,
                    scales: {
                        r: {
                            beginAtZero: true,
                            max: 10,
                            ticks: { stepSize: 1, font: { size: 12, weight: 'bold' } },
                            grid: { color: 'rgba(0, 0, 0, 0.1)' },
                            angleLines: { color: 'rgba(0, 0, 0, 0.1)' }
                        }
                    },
                    plugins: {
                        legend: { position: 'bottom', labels: { font: { size: 14, weight: 'bold' } } },
                        tooltip: {
                            callbacks: { label: context => context.label + ': ' + context.parsed.r + '/10' }
                        }
                    }
                }
            });
        }

        function renderAreasInfo(scores) {
            const container = document.getElementById('areas-info');
            container.innerHTML = '';

            areas.forEach((area, i) => {
                const score = scores[i];
                const div = document.createElement('div');
                div.className = `area-info ${score < 5 ? 'bg-red-100' : score < 8 ? 'bg-yellow-100' : 'bg-green-100'}`;
                div.style.borderLeftColor = colors[i];

                div.innerHTML = `
                    <div class="font-semibold text-gray-800 mb-2">${area.name}: ${score}/10</div>
                    <div class="text-sm text-gray-700">
                        ${score < 5 ? '<p class="font-semibold text-red-700">⚠️ Atenção Necessária</p><p>Área com prioridade de desenvolvimento.</p>' :
                          score < 8 ? '<p class="font-semibold text-yellow-700">📊 Desenvolvimento Possível</p><p>Há espaço para crescimento.</p>' :
                          '<p class="font-semibold text-green-700">✅ Ponto Forte</p><p>Mantenha esse bom nível!</p>'}
                    </div>
                `;
                container.appendChild(div);
            });
        }

        function renderTotalExplanation(totalScore) {
            const div = document.getElementById('total-explanation');
            let profile = '', explanation = '', alertClass = 'alert-success';

            if (totalScore >= 8.5) {
                profile = 'A: OUVINTE GENEROSO';
                explanation = `... (mantive exatamente o texto original que você tinha) ...`;
            } else if (totalScore >= 6.5) {
                profile = 'B: OUVINTE PRÁTICO';
                explanation = `...`;
            } else if (totalScore >= 4.5) {
                profile = 'C: OUVINTE SELETIVO';
                alertClass = 'alert-warning';
                explanation = `...`;
            } else {
                profile = 'D: OUVINTE DISTRAÍDO';
                alertClass = 'alert-danger';
                explanation = `...`;
            }

            div.innerHTML = `<div class="${alertClass} p-6 rounded-lg shadow-md"><h3 class="text-2xl font-bold text-center mb-4">${profile}</h3>${explanation}</div>`;
        }

        async function generatePDF() {
            const { jsPDF } = window.jspdf;
            const pdf = new jsPDF('p', 'mm', 'a4');
            const pageWidth = pdf.internal.pageSize.getWidth();
            const pageHeight = pdf.internal.pageSize.getHeight();

            const resultSection = document.getElementById('result-section');

            // Temporariamente mostrar a seção de resultados para capturar
            resultSection.classList.remove('hidden');
            document.getElementById('test-section').classList.add('hidden');
            document.getElementById('form-section').classList.add('hidden');

            const canvas = await html2canvas(resultSection, { scale: 2 });
            const imgData = canvas.toDataURL('image/png');

            const imgHeight = (canvas.height * pageWidth) / canvas.width;
            let heightLeft = imgHeight;
            let position = 10;

            pdf.addImage(imgData, 'PNG', 10, position, pageWidth - 20, imgHeight);
            heightLeft -= pageHeight;

            while (heightLeft >= 0) {
                position = heightLeft - imgHeight + 10;
                pdf.addPage();
                pdf.addImage(imgData, 'PNG', 10, position, pageWidth - 20, imgHeight);
                heightLeft -= pageHeight;
            }

            pdf.save(`Escuta_Ativa_${userData.name.replace(/\s+/g, '_')}.pdf`);
        }

        function resetTest() {
            currentQuestion = 0;
            responses.fill(1);
            userData = {};
            document.getElementById('form-section').classList.remove('hidden');
            document.getElementById('result-section').classList.add('hidden');
            document.getElementById('name').value = '';
            document.getElementById('age').value = '';
            document.getElementById('occupation').value = '';
            document.getElementById('email').value = '';
        }
    </script>
</body>
</html>
